# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jobsimply

# JWT
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# Frontend URL (production — your Vercel deployment URL)
# Used by CORS to allow requests from your frontend domain.
# In development, CORS falls back to localhost via CLIENT_ORIGIN.
FRONTEND_URL=http://localhost:5173

# AI Provider (choose one: openrouter, gemini, groq, regex)
AI_PROVIDER=regex

# API Keys (optional - only needed if using cloud AI providers)
OPENROUTER_API_KEY=
GEMINI_API_KEY=AQ.Ab8RN6LMtv6QojdGiphZTisnD0FCXRVBFGA-DDSpsJrm_flEDQ
GROQ_API_KEY=

# File Upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Chrome Extension ID (for CORS)
EXTENSION_ID=chrome-extension://your-extension-id